# ──────────────────────────────────────────────
# Live well — Server Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# Stripe Secret Key — REQUIRED
# Starts with sk_live_ (live) or sk_test_ (test)
# Get it: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_placeholder_replace_me

# Stripe Webhook Secret — OPTIONAL (needed for event confirmation)
# Starts with whsec_
# Get it: Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_placeholder_replace_me

# Server port (default 3001)
PORT=3001

# Allowed origins for CORS (comma-separated)
# Add your frontend URL here
CLIENT_ORIGIN=http://localhost:5173