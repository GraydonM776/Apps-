# ──────────────────────────────────────────────
# Live well — Server Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# Stripe Secret Key — REQUIRED
# Get it: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE

# Stripe Webhook Secret — OPTIONAL (needed for event confirmation)
# Get it: Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_KEY_HERE

# Server port (default 3001)
PORT=3001

# Allowed origins for CORS (comma-separated)
# Add your frontend URL here
CLIENT_ORIGIN=http://localhost:5173

# Product Price IDs — set these after running automate-stripe.js
# VITE_STRIPE_PRICE_SERUM=price_xxx
# VITE_STRIPE_PRICE_REFILL=price_xxx
# VITE_STRIPE_PRICE_SHOWER=price_xxx
# VITE_STRIPE_PRICE_FILTER=price_xxx
# VITE_STRIPE_PRICE_LAMP=price_xxx
# VITE_STRIPE_PRICE_SERUM_SUB=price_xxx
# VITE_STRIPE_PRICE_FILTER_SUB=price_xxx
