# Placeholder Stripe Keys
# Replace these with your real keys from https://dashboard.stripe.com/apikeys

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_replace_me

# Backend API URL (the Express server)
# In development: http://localhost:3001
# In production: https://your-api-domain.com
VITE_API_URL=http://localhost:3001

# Product Price IDs (create these in Stripe Dashboard → Products)
VITE_STRIPE_PRICE_SERUM=price_placeholder_serum
VITE_STRIPE_PRICE_REFILL=price_placeholder_refill
VITE_STRIPE_PRICE_SHOWER=price_placeholder_shower
VITE_STRIPE_PRICE_FILTER=price_placeholder_filter
VITE_STRIPE_PRICE_LAMP=price_placeholder_lamp
VITE_STRIPE_PRICE_SERUM_SUB=price_placeholder_serum_sub
VITE_STRIPE_PRICE_FILTER_SUB=price_placeholder_filter_sub